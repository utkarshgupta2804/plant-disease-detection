# =============================================================================
# /etc/udev/rules.d/99-ojas-devices.rules
# Team OJAS · NIT Hamirpur — Persistent device symlinks
#
# Install:
#   sudo cp 99-ojas-devices.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# After install, devices will always appear as:
#   /dev/lilygo   → LilyGo T-Display S3 AMOLED  (USB-C CDC)
#   /dev/nodemcu  → NodeMCU ESP8266/ESP32         (FTDI FT232 — confirmed 0403:6001)
#   /dev/npk      → NPK sensor via MAX485         (RPi hardware UART — see below)
#
# NOTE: /dev/npk is NOT a USB device — it is the RPi hardware UART.
#       It is symlinked via the setup_uart.sh script, not udev.
#       The two rules below are only for the USB serial devices.
#
# Chip reference (verified):
#   NodeMCU on this board → FTDI FT232RL  (0403:6001)
#   LilyGo T-Display S3  → ESP32-S3 CDC  (303a:1001)  or CP210x (10c4:ea60)
# =============================================================================

# --- LilyGo T-Display S3 AMOLED (ESP32-S3 native USB CDC) ---
ACTION=="add", SUBSYSTEM=="tty", \
  ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", \
  SYMLINK+="lilygo", MODE="0666"

# --- LilyGo fallback (CP210x-based variant) ---
ACTION=="add", SUBSYSTEM=="tty", \
  ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", \
  SYMLINK+="lilygo", MODE="0666"

# --- NodeMCU ESP8266/ESP32 (FTDI FT232RL — confirmed on this board) ---
ACTION=="add", SUBSYSTEM=="tty", \
  ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
  SYMLINK+="nodemcu", MODE="0666"

# --- NodeMCU fallback (CH340 chip — common on cheap NodeMCU v3 clones) ---
ACTION=="add", SUBSYSTEM=="tty", \
  ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", \
  SYMLINK+="nodemcu", MODE="0666"

# --- NodeMCU fallback (CP2102 chip) ---
ACTION=="add", SUBSYSTEM=="tty", \
  ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", \
  SYMLINK+="nodemcu_cp", MODE="0666"